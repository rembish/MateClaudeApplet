#!/usr/bin/env python3
"""Claude plan usage MATE panel applet."""

import json
import locale
import os
import subprocess
import threading
import time
import urllib.error
import urllib.request
from datetime import datetime
from pathlib import Path

import gi

gi.require_version("MatePanelApplet", "4.0")
gi.require_version("Gtk", "3.0")
from gi.repository import GLib, Gtk, MatePanelApplet

USAGE_URL = "https://api.anthropic.com/api/oauth/usage"
CACHE_FILE = Path("/tmp/claude/statusline-usage-cache.json")
CACHE_MAX_AGE = 60
REFRESH_INTERVAL = 60

MONTHS = ["jan","feb","mar","apr","may","jun","jul","aug","sep","oct","nov","dec"]
locale.setlocale(locale.LC_TIME, "")
_USE_24H = "13" in datetime(2000, 1, 1, 13, 0).strftime(locale.nl_langinfo(locale.T_FMT))


def get_oauth_token() -> str:
    token = os.environ.get("CLAUDE_CODE_OAUTH_TOKEN", "")
    if token:
        return token

    creds_file = Path.home() / ".claude" / ".credentials.json"
    if creds_file.exists():
        try:
            data = json.loads(creds_file.read_text())
            token = data.get("claudeAiOauth", {}).get("accessToken", "")
            if token:
                return token
        except Exception:
            pass

    try:
        result = subprocess.run(
            ["secret-tool", "lookup", "service", "Claude Code-credentials"],
            capture_output=True, text=True, timeout=2,
        )
        if result.returncode == 0 and result.stdout.strip():
            data = json.loads(result.stdout)
            token = data.get("claudeAiOauth", {}).get("accessToken", "")
            if token:
                return token
    except Exception:
        pass

    return ""


def fetch_usage(token: str) -> tuple[dict | None, int | None]:
    req = urllib.request.Request(
        USAGE_URL,
        headers={
            "Accept": "application/json",
            "Content-Type": "application/json",
            "Authorization": f"Bearer {token}",
            "anthropic-beta": "oauth-2025-04-20",
            "User-Agent": "claude-code/2.1.34",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=5) as resp:
            data = json.loads(resp.read())
            if "five_hour" in data:
                CACHE_FILE.parent.mkdir(parents=True, exist_ok=True)
                CACHE_FILE.write_text(json.dumps(data))
                return data, resp.status
    except urllib.error.HTTPError as e:
        return None, e.code
    except Exception:
        pass
    return None, None


def load_usage() -> tuple[dict | None, str | None]:
    if CACHE_FILE.exists():
        age = time.time() - CACHE_FILE.stat().st_mtime
        if age < CACHE_MAX_AGE:
            try:
                return json.loads(CACHE_FILE.read_text()), None
            except Exception:
                pass

    token = get_oauth_token()
    if not token:
        if CACHE_FILE.exists():
            try:
                return json.loads(CACHE_FILE.read_text()), None
            except Exception:
                pass
        return None, "no token"

    data, status = fetch_usage(token)
    if data is not None:
        return data, None

    if status == 401:
        return None, "token expired"
    if status is not None:
        return None, f"error {status}"

    if CACHE_FILE.exists():
        try:
            return json.loads(CACHE_FILE.read_text()), None
        except Exception:
            pass

    return None, "offline"


def pct_color(pct: float) -> str:
    if pct >= 70:
        return "#e05050"
    if pct >= 40:
        return "#d49020"
    return "#409040"


def format_reset(iso_str: str, style: str = "time") -> str:
    if not iso_str:
        return ""
    try:
        dt = datetime.fromisoformat(iso_str.replace("Z", "+00:00"))
        local = dt.astimezone()
        minute = local.strftime("%M")
        if _USE_24H:
            time_str = f"{local.hour}:{minute}"
        else:
            hour = int(local.strftime("%I"))
            ampm = "am" if local.hour < 12 else "pm"
            time_str = f"{hour}:{minute}{ampm}"
        if style == "time":
            return time_str
        month = MONTHS[local.month - 1]
        return f"{month} {local.day}, {time_str}"
    except Exception:
        return ""


class ClaudeMateApplet:
    def __init__(self, applet: MatePanelApplet.Applet):
        self.applet = applet
        self.five_label: Gtk.Label | None = None
        self.sep: Gtk.Label | None = None
        self.week_label: Gtk.Label | None = None

        applet.connect("realize", self._on_realize)
        self._setup_menu()

    def _setup_menu(self):
        group = Gtk.ActionGroup(name="mate-claude-applet-group")
        refresh_action = Gtk.Action(
            name="Refresh", label="Refresh", tooltip=None, stock_id=None
        )
        refresh_action.connect("activate", lambda *_: self.refresh())
        group.add_action(refresh_action)

        self.applet.setup_menu(
            '<menuitem name="ClaudeMateRefresh" action="Refresh"/>',
            group,
        )

    def _on_realize(self, _applet):
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=4)
        box.set_margin_start(4)
        box.set_margin_end(4)

        logo_label = Gtk.Label()
        logo_label.set_markup('<b><span color="#ff8c00">CC</span></b>')
        self.five_label = Gtk.Label(label="Claude …")
        self.sep = Gtk.Label(label="·")
        self.week_label = Gtk.Label(label="")

        box.pack_start(logo_label, False, False, 0)
        box.pack_start(self.five_label, False, False, 0)
        box.pack_start(self.sep, False, False, 0)
        box.pack_start(self.week_label, False, False, 0)

        self.applet.add(box)
        box.show_all()

        self.refresh()
        GLib.timeout_add_seconds(REFRESH_INTERVAL, self._on_timer)

    def _on_timer(self) -> bool:
        self.refresh()
        return True

    def refresh(self):
        threading.Thread(target=self._fetch_thread, daemon=True).start()

    def _fetch_thread(self):
        data, error = load_usage()
        GLib.idle_add(self._update, data, error)

    def _update(self, data: dict | None, error: str | None) -> bool:
        if self.five_label is None:
            return False

        if data is None:
            self.five_label.set_markup(
                f'<span color="#e05050">Claude: {error}</span>'
            )
            self.sep.hide()
            self.week_label.set_text("")
            return False

        five = data.get("five_hour", {})
        five_pct = float(five.get("utilization", 0))
        five_reset = format_reset(five.get("resets_at", ""), "time")

        weekly = data.get("seven_day", {})
        week_pct = float(weekly.get("utilization", 0))
        week_reset = format_reset(weekly.get("resets_at", ""), "datetime")

        self.five_label.set_markup(
            f'5h: <b><span color="{pct_color(five_pct)}">{five_pct:g}%</span></b>'
        )
        self.five_label.set_tooltip_text(f"Resets {five_reset}" if five_reset else "")

        self.sep.show()

        self.week_label.set_markup(
            f'W: <b><span color="{pct_color(week_pct)}">{week_pct:g}%</span></b>'
        )
        self.week_label.set_tooltip_text(f"Resets {week_reset}" if week_reset else "")

        return False


def applet_factory(
    applet: MatePanelApplet.Applet,
    iid: str,
    _data: object,
) -> bool:
    if iid != "MateClaudeApplet":
        return False
    ClaudeMateApplet(applet)
    applet.show()
    return True


MatePanelApplet.Applet.factory_main(
    "MateClaudeAppletFactory",
    True,
    MatePanelApplet.Applet.__gtype__,
    applet_factory,
    None,
)
